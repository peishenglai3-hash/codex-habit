# Codex Habit - .gitignore

# Dependencies
node_modules/

# OS files
.DS_Store
Thumbs.db

# Python cache
__pycache__/
*.pyc

# Local env
.env
.env.local

# IDE
.idea/
.vscode/
*.swp

# Logs
*.log
logs/

# Third-party skills (installed via npx skills add)
.agents/skills/*
# But keep our own skill
!.agents/skills/codex-habit-skill/

# Internal development scripts
scripts/capture_batch.py
scripts/rebuild_*.py
skills-lock.json

# Temp auth scripts
scripts/askpass.sh
scripts/git-askpass.ps1
